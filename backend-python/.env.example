# Database URI configuration.
# Use SQLite local file for quick testing: sqlite:///./tasks.db
# Or use full PostgreSQL in production: postgresql+psycopg2://user:password@localhost:5432/taskhq_db
DATABASE_URL="sqlite:///./tasks.db"

# Secure Cryptographic Salt Key (run openssl rand -hex 32 to generate)
JWT_SECRET_KEY="super-secret-hexadecimal-salt-key-for-jwt-signing"

# Selected algorithm matching standards
JWT_ALGORITHM="HS256"

# Session expire threshold (e.g. 1440 minutes = 24 Hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
